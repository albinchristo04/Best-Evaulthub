---
export interface Props {
  title?: string;
  slug?: string;
}
const { title = 'Ver Partido en Vivo', slug = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="referrer" content="origin" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #000;
      color: #f0f0f0;
      font-family: system-ui, -apple-system, sans-serif;
      display: flex;
      flex-direction: column;
      height: 100dvh;
      overflow: hidden;
    }
    .embed-bar {
      background: #12121a;
      border-bottom: 1px solid #ffffff15;
      padding: 0.4rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      gap: 0.5rem;
    }
    .embed-brand {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      font-weight: 700;
      color: #f0f0f0;
      text-decoration: none;
    }
    .embed-brand-icon {
      width: 18px; height: 18px;
      background: #e53e3e;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 8px;
      color: #fff;
    }
    .embed-watch-link {
      font-size: 0.72rem;
      color: #e53e3e;
      text-decoration: none;
      font-weight: 600;
      white-space: nowrap;
    }
    .embed-watch-link:hover { text-decoration: underline; }
    .embed-content {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .embed-content::slotted(*) { flex: 1; }
  </style>
  <!-- Adsterra Popup -->
  <script src="https://pl29031831.profitablecpmratenetwork.com/99/19/f6/9919f61cfc44e5526b3b8d954079e2fd.js"></script>
</head>
<body>
  <div class="embed-bar">
    <a href="https://deportesenvivo.live" target="_blank" rel="noopener" class="embed-brand">
      <div class="embed-brand-icon">▶</div>
      deportesenvivo.live
    </a>
    <a
      href={`https://deportesenvivo.live/match/${slug}`}
      target="_blank"
      rel="noopener"
      class="embed-watch-link"
    >
      Ver en sitio →
    </a>
  </div>
  <div class="embed-content">
    <slot />
  </div>
</body>
</html>
