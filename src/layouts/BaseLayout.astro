---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalUrl?: string;
  ogType?: string;
  jsonLd?: object | object[];
  pageType?: 'home' | 'hub' | 'match' | 'embed' | 'share';
  matchId?: string;
  ogImage?: string;
}

const {
  title,
  description,
  keywords = '',
  canonicalUrl = 'https://deportesenvivo.live/',
  ogType = 'website',
  jsonLd,
  pageType = 'home',
  matchId = '',
  ogImage = 'https://deportesenvivo.live/og-image.png',
} = Astro.props;

const fullTitle = `${title} | Deportes en Vivo`;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content="index, follow" />
    <meta name="language" content="Spanish" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Deportes en Vivo" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Global CSS injected via Astro import in frontmatter -->

    <!-- JSON-LD Structured Data -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : jsonLd)} />
    )}

    <!-- Adsterra Popup Ad -->
    <script async src="https://widthwidowzoology.com/99/19/f6/9919f61cfc44e5526b3b8d954079e2fd.js"></script>

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "w4w3im378q");
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-WRWK9LDSH1"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-WRWK9LDSH1');
    </script>
  </head>
  <body>
    <!-- Supabase config for client-side tracking -->
    <div
      id="supabase-config"
      data-url={import.meta.env.SUPABASE_URL || "https://cwxcpqwqypcgvxfchccm.supabase.co"}
      data-key={import.meta.env.SUPABASE_ANON_KEY || "sb_publishable_qk446pkZuU6Gu256Zx4NwA_7r9mGHxQ"}
      data-page-type={pageType}
      data-match-id={matchId}
      hidden
    ></div>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Supabase Page View Tracking -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        try {
          const cfg = document.getElementById('supabase-config');
          if (!cfg) return;
          const SUPABASE_URL = cfg.dataset.url;
          const SUPABASE_ANON_KEY = cfg.dataset.key;
          if (!SUPABASE_URL || !SUPABASE_ANON_KEY) return;
          const pageType = cfg.dataset.pageType || 'home';
          const matchId = cfg.dataset.matchId || null;
          fetch(`${SUPABASE_URL}/rest/v1/page_views`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
              'Prefer': 'return=minimal',
            },
            body: JSON.stringify({
              page_path: window.location.pathname,
              page_type: pageType,
              match_id: matchId || undefined,
              referrer: document.referrer || null,
            }),
          }).catch(() => {});
        } catch (_) {}
      });
    </script>
  </body>
</html>
