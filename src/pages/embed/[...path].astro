---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
import allMatches from '../../data/all-matches.json';

export async function getStaticPaths() {
  type Match = (typeof allMatches)[number];

  // Deduplicate by id
  const seen = new Set<string>();
  const unique: Match[] = [];
  for (const m of allMatches) {
    if (!seen.has(m.id)) { seen.add(m.id); unique.push(m); }
  }

  return unique.map(m => ({
    params: { path: m.id },
    props: { slug: m.id, teams: m.teams, events: allMatches.filter(e => e.id === m.id) },
  }));
}

type Match = (typeof allMatches)[number];

export interface Props {
  slug: string;
  teams: string;
  events: Match[];
}

const { slug, teams, events } = Astro.props;
const SUPABASE_URL = import.meta.env.SUPABASE_URL || 'https://cwxcpqwqypcgvxfchccm.supabase.co';
const SUPABASE_KEY = import.meta.env.SUPABASE_ANON_KEY || 'sb_publishable_qk446pkZuU6Gu256Zx4NwA_7r9mGHxQ';
---

<EmbedLayout title={`${teams} en Vivo`} slug={slug}>
  <div
    id="embed-data"
    data-slug={slug}
    data-events={JSON.stringify(events)}
    data-supabase-url={SUPABASE_URL}
    data-supabase-key={SUPABASE_KEY}
    hidden
  ></div>
  <div class="embed-player-wrap">
    <iframe
      id="embed-player"
      src=""
      allow="autoplay; encrypted-media; fullscreen" referrerpolicy="no-referrer"
      allowfullscreen
      style="width:100%;height:100%;border:none;"
      title={`Ver ${teams} en vivo`}
    ></iframe>
  </div>
</EmbedLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const dataEl = document.getElementById('embed-data');
    if (!dataEl) return;

    const slug = dataEl.dataset.slug || '';
    const events = JSON.parse(dataEl.dataset.events || '[]');
    const SUPABASE_URL = dataEl.dataset.supabaseUrl || '';
    const SUPABASE_KEY = dataEl.dataset.supabaseKey || '';

    // Read query params
    const params = new URLSearchParams(window.location.search);
    const serverNum = parseInt(params.get('s') || '1');
    const channelIdx = parseInt(params.get('ch') || '0');

    // Find the right event
    const serverEvents = events.filter((e: any) => e.server === serverNum);
    const event = serverEvents[0] || events[0];
    if (!event) return;

    const channels = event.channels || [];
    const embedUrl = channels[channelIdx]?.embedUrl || channels[0]?.embedUrl || '';

    const player = document.getElementById('embed-player');
    if (player && embedUrl) {
      if (serverNum === 3) {
        player.removeAttribute('sandbox');
      } else {
        player.setAttribute('sandbox', 'allow-scripts allow-same-origin');
      }
      player.src = embedUrl;
    }

    // Supabase tracking
    if (SUPABASE_URL && SUPABASE_KEY) {
      fetch(`${SUPABASE_URL}/rest/v1/embed_views`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${SUPABASE_KEY}`,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({
          match_slug: slug,
          source_server: `s${serverNum}`,
          referrer_domain: document.referrer
            ? (() => { try { return new URL(document.referrer).hostname; } catch { return null; } })()
            : null,
        }),
      }).catch(() => {});
    }
  });
</script>

<!-- Popup / redirect blocker -->
<script>
  window.open = function() { return null; };
  window.addEventListener('blur', () => {
    setTimeout(() => window.focus(), 50);
  });
</script>

<style>
  .embed-player-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  #embed-player {
    flex: 1;
  }
</style>
