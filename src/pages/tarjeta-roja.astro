---
import BaseLayout from '../layouts/BaseLayout.astro';
import MatchGrid from '../components/MatchGrid.astro';
import ServerTabs from '../components/ServerTabs.astro';
import FAQ from '../components/FAQ.astro';
import s1Matches from '../data/s1-matches.json';
import s2Matches from '../data/s2-matches.json';
import s3Matches from '../data/s3-matches.json';

const title = "Tarjeta Roja TV - Partidos de Fútbol en Vivo Gratis";
const description = "Tarjeta Roja TV online. Ver partidos de fútbol en vivo gratis hoy.";
const keywords = "tarjeta roja, tarjeta roja tv, tarjeta roja en vivo, tarjeta roja online, tarjeta roja fútbol";

const filterCategory = "football";
const filteredS1 = s1Matches.filter((m: any) => m.category === filterCategory);
const filteredS2 = s2Matches.filter((m: any) => m.category === filterCategory);
const filteredS3 = s3Matches.filter((m: any) => m.category === filterCategory);

const faqItems = [
  {
    question: "¿Qué es Tarjeta Roja TV?",
    answer: "Tarjeta Roja TV es un popular sitio de streaming de fútbol gratuito muy conocido entre los aficionados de habla hispana. Ofrece partidos en vivo de las principales ligas europeas y competiciones internacionales. En deportesenvivo.live encuentras una alternativa completa con múltiples servidores.",
  },
  {
    question: "¿Puedo ver la Champions League en Tarjeta Roja?",
    answer: "Sí. En deportesenvivo.live encontrarás transmisiones en vivo de Champions League, Europa League, LaLiga, Premier League, Serie A y todas las grandes competiciones. La cartelera se actualiza diariamente con los partidos del día.",
  },
  {
    question: "¿Tarjeta Roja funciona sin registro?",
    answer: "Exactamente. Tanto Tarjeta Roja como deportesenvivo.live permiten ver fútbol sin necesidad de crear ninguna cuenta. Entra al sitio, elige el partido y empieza a ver inmediatamente.",
  },
  {
    question: "¿Por qué Tarjeta Roja a veces no carga?",
    answer: "Los sitios de streaming gratuito a veces tienen problemas de disponibilidad por el alto tráfico o cambios de dominio. En deportesenvivo.live contamos con tres servidores redundantes para que siempre tengas una alternativa funcionando.",
  },
  {
    question: "¿Es legal ver fútbol en Tarjeta Roja o sitios similares?",
    answer: "Las leyes sobre el consumo de streaming varían según el país. deportesenvivo.live actúa como directorio de streams públicos y no aloja ni distribuye contenido protegido directamente. Consulta la normativa de tu país para más información.",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalUrl="https://deportesenvivo.live/tarjeta-roja"
  pageType="hub"
>
  <div class="container">
    <div class="page-header">
      <h1>Tarjeta Roja</h1>
      <p class="subtitle">Ver partidos de fútbol en vivo gratis — alternativa a Tarjeta Roja TV online</p>
    </div>

    <ServerTabs activeServer={1} />

    <div id="server-content-1">
      <MatchGrid matches={filteredS1} serverNum={1} />
    </div>
    <div id="server-content-2" hidden>
      <MatchGrid matches={filteredS2} serverNum={2} />
    </div>
    <div id="server-content-3" hidden>
      <MatchGrid matches={filteredS3} serverNum={3} />
    </div>

    <div class="seo-content">
      <h2>Tarjeta Roja TV — Ver Fútbol Gratis en Directo</h2>
      <p>
        <strong>Tarjeta Roja</strong> es uno de los sitios de streaming de fútbol más reconocidos en el mundo hispanohablante. En deportesenvivo.live encuentras la mejor alternativa a <strong>Tarjeta Roja TV</strong>, con transmisiones en vivo de los partidos más importantes del día. Ver <strong>fútbol gratis</strong> nunca ha sido tan sencillo: sin registro, sin descargas y con múltiples servidores disponibles para garantizar siempre una transmisión estable.
      </p>
      <p>
        Para seguir <strong>Tarjeta Roja en vivo</strong>, simplemente navega por los partidos disponibles arriba y elige el que quieras ver. Si el Servidor 1 no funciona, prueba con el Servidor 2 o el Servidor 3. Cubrimos toda la programación futbolística del día: LaLiga, Premier League, Serie A, Bundesliga, Champions League, Europa League y selecciones nacionales.
      </p>
      <p>
        Descubre también otras páginas del sitio como <a href="/futbol-libre">Fútbol Libre</a>, <a href="/pirlo-tv">Pirlo TV</a>, <a href="/roja-directa">Roja Directa</a> o <a href="/partidos-de-hoy">Partidos de Hoy</a> para encontrar siempre el partido que buscas. Comparte la cartelera deportiva del día con tus amigos en WhatsApp usando nuestra <a href="/compartir">herramienta de compartir</a>.
      </p>
    </div>

    <FAQ items={faqItems} />
  </div>
</BaseLayout>
