---
import BaseLayout from '../layouts/BaseLayout.astro';
import MatchGrid from '../components/MatchGrid.astro';
import ServerTabs from '../components/ServerTabs.astro';
import FAQ from '../components/FAQ.astro';
import s1Matches from '../data/s1-matches.json';
import s2Matches from '../data/s2-matches.json';
import s3Matches from '../data/s3-matches.json';

const title = "Pirlo TV en Vivo - Ver Deportes Gratis";
const description = "Pirlo TV en vivo gratis. Ver fútbol y deportes por internet sin registro.";
const keywords = "pirlo tv, pirlo tv en vivo, pirlo tv hoy, pirlotv, pirlo tv hd, pirlo tv online, pirlo tv rojadirecta, ver pirlo tv gratis, pirlo tv partidos hoy";

const faqItems = [
  {
    question: "¿Qué es Pirlo TV?",
    answer: "Pirlo TV es uno de los sitios de streaming deportivo más conocidos en el mundo de habla hispana. Ofrece transmisiones en vivo de fútbol y otros deportes de forma gratuita. En deportesenvivo.live encontrarás contenido similar y de alta calidad con múltiples servidores disponibles.",
  },
  {
    question: "¿Pirlo TV sigue funcionando en 2026?",
    answer: "Los sitios de streaming gratuito cambian frecuentemente de dominio o están sujetos a interrupciones. Por eso, deportesenvivo.live es una excelente alternativa a Pirlo TV, con tres servidores redundantes para garantizar disponibilidad continua.",
  },
  {
    question: "¿Cómo ver Pirlo TV en vivo en mi celular?",
    answer: "En deportesenvivo.live puedes acceder desde cualquier dispositivo móvil sin instalar aplicaciones. Abre el navegador, entra al sitio, selecciona el partido y listo. Funciona en Android e iOS perfectamente.",
  },
  {
    question: "¿Pirlo TV tiene partidos de Champions League?",
    answer: "Sí, en esta página encontrarás transmisiones de Champions League, Europa League, LaLiga, Premier League y todas las grandes competiciones de fútbol mundial. La programación se actualiza diariamente.",
  },
  {
    question: "¿Necesito VPN para ver Pirlo TV?",
    answer: "No necesitas VPN para acceder a deportesenvivo.live. El sitio está disponible globalmente sin restricciones geográficas. Accede directamente desde tu navegador en cualquier país.",
  },
  {
    question: "¿Cuál es la diferencia entre Pirlo TV y PirloTV?",
    answer: "Pirlo TV y PirloTV (sin espacio ni guion) hacen referencia al mismo tipo de servicio de streaming deportivo gratuito. En deportesenvivo.live encontrarás ambas experiencias en un solo sitio, con tres servidores y actualización constante.",
  },
  {
    question: "¿Pirlo TV tiene retransmisiones de rojadirecta?",
    answer: "Muchos usuarios buscan 'pirlo tv rojadirecta' porque ambos sitios son conocidos por sus streams deportivos gratuitos. En deportesenvivo.live combinamos lo mejor de ambas fuentes con múltiples servidores y cobertura completa de fútbol y otros deportes.",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalUrl="https://deportesenvivo.live/pirlo-tv"
  pageType="hub"
>
  <div class="container">
    <div class="page-header">
      <h1>Pirlo TV</h1>
      <p class="subtitle">Ver fútbol y deportes en vivo gratis — la mejor alternativa a Pirlo TV online</p>
    </div>

    <ServerTabs activeServer={1} />

    <div id="server-content-1">
      <MatchGrid matches={s1Matches} serverNum={1} />
    </div>
    <div id="server-content-2" hidden>
      <MatchGrid matches={s2Matches} serverNum={2} />
    </div>
    <div id="server-content-3" hidden>
      <MatchGrid matches={s3Matches} serverNum={3} />
    </div>

    <div class="seo-content">
      <h2>Pirlo TV en Vivo — Streaming Deportivo Gratuito</h2>
      <p>
        <strong>Pirlo TV</strong> se ha convertido en uno de los nombres más buscados cuando se trata de ver deportes en vivo gratis por internet. En deportesenvivo.live ofrecemos la mejor alternativa a <strong>Pirlo TV en vivo</strong>, con transmisiones de fútbol, baloncesto, béisbol y más deportes disponibles las 24 horas del día. No necesitas registrarte ni introducir datos personales para empezar a ver tus partidos favoritos.
      </p>
      <p>
        Si buscas <strong>Pirlo TV hoy</strong> para ver un partido específico, aquí encontrarás la programación completa del día con indicadores en tiempo real de los eventos que están EN VIVO en este momento. Nuestra plataforma cuenta con tres servidores distintos para garantizar que siempre tengas acceso a los streams aunque uno falle. Navega también por nuestras páginas de <a href="/futbol-libre">Fútbol Libre</a>, <a href="/tarjeta-roja">Tarjeta Roja</a> o <a href="/roja-directa">Roja Directa</a> para más opciones.
      </p>
      <p>
        Para <strong>ver Pirlo TV online</strong> desde tu móvil, tablet o computadora, solo necesitas un navegador actualizado. Sin plugins, sin aplicaciones adicionales, sin complicaciones. Disfruta del deporte en vivo con la mejor calidad disponible y comparte los partidos con tus amigos usando nuestra <a href="/compartir">herramienta de compartir</a>.
      </p>
      <h3>Pirlo TV HD — La mejor calidad de streaming</h3>
      <p>
        Si buscas <strong>pirlo tv hd</strong> para ver partidos en alta definición, en deportesenvivo.live ofrecemos streams en la máxima calidad disponible. También conocido como <strong>pirlotv</strong> (sin espacio), es el destino favorito de los aficionados al fútbol y los deportes en español. Busca <strong>pirlo tv rojadirecta</strong> y encontrarás aquí la mejor alternativa combinada.
      </p>
    </div>

    <FAQ items={faqItems} />

    <div class="alternatives-box">
      <h3>Otras alternativas populares</h3>
      <div class="alt-links">
        <a href="/pirlotv">PirloTV</a>
        <a href="/tarjeta-roja">Tarjeta Roja</a>
        <a href="/futbol-libre">Fútbol Libre</a>
        <a href="/roja-directa">Roja Directa</a>
        <a href="/rojadirecta-tv">Rojadirecta TV</a>
        <a href="/la-roja-directa">La Roja Directa</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .alternatives-box {
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .alternatives-box h3 {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .alt-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .alt-links a {
    padding: 0.3rem 0.85rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.85rem;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .alt-links a:hover { border-color: var(--primary); color: var(--primary); }
</style>
