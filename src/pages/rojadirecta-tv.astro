---
import BaseLayout from '../layouts/BaseLayout.astro';
import MatchGrid from '../components/MatchGrid.astro';
import ServerTabs from '../components/ServerTabs.astro';
import FAQ from '../components/FAQ.astro';
import s1Matches from '../data/s1-matches.json';
import s2Matches from '../data/s2-matches.json';
import s3Matches from '../data/s3-matches.json';

const title = "Rojadirecta TV en Vivo - Todos los Partidos Hoy";
const description = "Rojadirecta TV en vivo. Todos los partidos de hoy en directo gratis.";
const keywords = "rojadirecta tv, rojadirecta tv en vivo, rojadirecta partidos, rojadirecta hoy";

const faqItems = [
  {
    question: "¿Qué es Rojadirecta TV?",
    answer: "Rojadirecta TV es la versión televisiva del conocido directorio de streaming deportivo Rojadirecta. Ofrece acceso a múltiples canales y transmisiones de deportes en vivo. En deportesenvivo.live encontrarás una plataforma equivalente con contenido actualizado diariamente.",
  },
  {
    question: "¿Rojadirecta TV tiene todos los partidos de hoy?",
    answer: "En deportesenvivo.live actualizamos la programación cada 30 minutos con todos los partidos disponibles del día. Desde la madrugada hasta la noche, cubrimos fútbol, NBA, MLB, tenis y más deportes en directo.",
  },
  {
    question: "¿Cómo usar Rojadirecta TV en vivo?",
    answer: "En deportesenvivo.live simplemente entra al sitio, busca el partido que te interesa en la cartelera del día y haz clic en 'Ver en vivo'. Elige el servidor que mejor funcione en tu conexión y disfruta del partido en alta calidad.",
  },
  {
    question: "¿Rojadirecta TV tiene canales de televisión?",
    answer: "deportesenvivo.live integra canales de distintos países y fuentes para ofrecerte la mayor cobertura posible de eventos deportivos. Cada partido puede tener varios canales disponibles en distintos idiomas.",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalUrl="https://deportesenvivo.live/rojadirecta-tv"
  pageType="hub"
>
  <div class="container">
    <div class="page-header">
      <h1>Rojadirecta TV</h1>
      <p class="subtitle">Todos los partidos de hoy en directo gratis — Rojadirecta TV en vivo</p>
    </div>

    <ServerTabs activeServer={1} />

    <div id="server-content-1">
      <MatchGrid matches={s1Matches} serverNum={1} />
    </div>
    <div id="server-content-2" hidden>
      <MatchGrid matches={s2Matches} serverNum={2} />
    </div>
    <div id="server-content-3" hidden>
      <MatchGrid matches={s3Matches} serverNum={3} />
    </div>

    <div class="seo-content">
      <h2>Rojadirecta TV — Partidos en Directo Hoy</h2>
      <p>
        <strong>Rojadirecta TV</strong> es uno de los recursos más buscados por los aficionados al deporte en español. En deportesenvivo.live ofrecemos la experiencia completa de <strong>Rojadirecta TV en vivo</strong>: una cartelera actualizada con todos los <strong>partidos de hoy</strong> en directo, con acceso gratuito desde cualquier dispositivo. Fútbol, NBA, MLB, tenis y más deportes reunidos en una sola plataforma.
      </p>
      <p>
        La programación de <strong>Rojadirecta hoy</strong> se refleja en nuestra cartelera de partidos, que se actualiza automáticamente cada 30 minutos. Cada partido tiene varios servidores disponibles para que siempre encuentres una transmisión funcionando. Los horarios se muestran en tu zona horaria local automáticamente.
      </p>
      <p>
        Visita también <a href="/roja-directa">Roja Directa</a>, <a href="/rojadirecta-en-vivo">Rojadirecta en Vivo</a>, <a href="/tarjeta-roja-tv">Tarjeta Roja TV</a> o <a href="/partidos-en-vivo">Partidos en Vivo</a> para más opciones. Usa la <a href="/compartir">herramienta de compartir</a> para enviar el calendario deportivo de hoy a tus contactos.
      </p>
    </div>

    <FAQ items={faqItems} />
  </div>
</BaseLayout>
