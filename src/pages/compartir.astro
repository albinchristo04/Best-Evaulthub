---
import BaseLayout from '../layouts/BaseLayout.astro';
import allMatches from '../data/all-matches.json';
---

<BaseLayout
  title="Compartir Partidos de Hoy"
  description="Comparte los partidos de hoy por Telegram o WhatsApp. Organizados por servidor."
  canonicalUrl="https://deportesenvivo.live/compartir"
  pageType="share"
>
  <div class="container">
    <div class="page-header">
      <h1>📤 Compartir Partidos de Hoy</h1>
      <p class="subtitle">Solo partidos de hoy · Organizados por servidor · Formato Telegram/WhatsApp</p>
    </div>

    <div id="share-root" data-matches={JSON.stringify(allMatches)}></div>
  </div>
</BaseLayout>

<script>
  const SITE = 'deportesenvivo.live';

  const EMOJI: Record<string, string> = {
    football: '⚽', basketball: '🏀', baseball: '⚾', tennis: '🎾',
    cricket: '🏏', hockey: '🏒', boxing: '🥊', mma: '🥊', darts: '🎯', other: '🏆'
  };
  const CAT_LABEL: Record<string, string> = {
    football: 'FÚTBOL', basketball: 'NBA / BALONCESTO', baseball: 'MLB / BÉISBOL',
    tennis: 'TENIS', cricket: 'CRICKET', hockey: 'HOCKEY', boxing: 'BOXEO',
    mma: 'MMA / UFC', darts: 'DARDOS', other: 'OTROS DEPORTES'
  };
  const SERVER_LABEL: Record<number, string> = { 1: 'Servidor 1', 2: 'Servidor 2', 3: 'Servidor 3' };

  interface Match {
    id: string;
    teams: string;
    category: string;
    startTime: number;
    endTime: number;
    server: number;
  }

  function isToday(ts: number): boolean {
    if (!ts) return true; // no timestamp = assume live/today
    const d = new Date(ts * 1000);
    const now = new Date();
    return d.getFullYear() === now.getFullYear()
      && d.getMonth() === now.getMonth()
      && d.getDate() === now.getDate();
  }

  function formatTime(ts: number): string {
    if (!ts) return '🔴';
    return new Intl.DateTimeFormat(navigator.language || 'es', {
      hour: '2-digit', minute: '2-digit'
    }).format(new Date(ts * 1000));
  }

  function formatDate(): string {
    return new Intl.DateTimeFormat('es-ES', {
      day: '2-digit', month: '2-digit', year: 'numeric'
    }).format(new Date());
  }

  function isLive(m: Match): boolean {
    const now = Math.floor(Date.now() / 1000);
    return m.startTime > 0 && now >= m.startTime && (m.endTime === 0 || now <= m.endTime);
  }

  function buildServerText(matches: Match[], serverNum: number): string {
    const byCategory: Record<string, Match[]> = {};
    matches.forEach(m => {
      if (!byCategory[m.category]) byCategory[m.category] = [];
      byCategory[m.category].push(m);
    });
    let text = `🔴 DEPORTES EN VIVO - ${formatDate()}\n${SERVER_LABEL[serverNum]} · https://${SITE}\n`;
    for (const [cat, evts] of Object.entries(byCategory)) {
      text += `\n${EMOJI[cat] || '🏆'} ${CAT_LABEL[cat] || cat.toUpperCase()}\n\n`;
      evts.forEach(m => {
        const live = isLive(m) ? ' 🔴 EN VIVO' : '';
        text += `• ${formatTime(m.startTime)}${live} ${m.teams}\n  https://${SITE}/match/${m.id}\n\n`;
      });
    }
    text += `📺 Ver todos → https://${SITE}`;
    return text;
  }

  function copyText(text: string, btn: HTMLButtonElement) {
    const orig = btn.textContent!;
    const done = () => { btn.textContent = '✅ Copiado!'; btn.disabled = true; setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000); };
    navigator.clipboard.writeText(text).then(done).catch(() => {
      const ta = Object.assign(document.createElement('textarea'), { value: text, style: 'position:fixed;opacity:0' });
      document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
      done();
    });
  }

  function renderServer(matches: Match[], serverNum: number, selected: Set<string>): string {
    if (!matches.length) return `<p class="share-empty">Sin partidos de hoy en ${SERVER_LABEL[serverNum]}.</p>`;

    const byCategory: Record<string, Match[]> = {};
    matches.forEach(m => { if (!byCategory[m.category]) byCategory[m.category] = []; byCategory[m.category].push(m); });

    let html = `<div class="share-server-panel" data-server="${serverNum}">`;
    html += `<div class="share-server-actions">
      <button class="btn btn-primary share-copy-server" data-server="${serverNum}">📋 Copiar Servidor ${serverNum}</button>
      <button class="btn btn-outline share-select-all" data-server="${serverNum}">☑ Todos</button>
      <button class="btn btn-outline share-deselect-all" data-server="${serverNum}">☐ Ninguno</button>
      <span class="share-count" data-server="${serverNum}">${matches.length} partidos</span>
    </div>`;

    for (const [cat, evts] of Object.entries(byCategory)) {
      html += `<div class="share-category">
        <div class="share-cat-header">
          <span>${EMOJI[cat] || '🏆'} ${CAT_LABEL[cat] || cat}</span>
          <button class="share-cat-copy btn btn-outline" data-server="${serverNum}" data-cat="${cat}">Copiar ${EMOJI[cat] || ''}</button>
        </div>`;
      evts.forEach(m => {
        const live = isLive(m);
        const chk = `chk-s${serverNum}-${m.id}`;
        html += `<label class="share-match-row${live ? ' is-live' : ''}" for="${chk}">
          <input type="checkbox" id="${chk}" data-id="${m.id}" data-server="${serverNum}" ${selected.has(m.id + '-' + serverNum) ? 'checked' : ''}/>
          <span class="share-match-time">${live ? '🔴' : formatTime(m.startTime)}</span>
          <span class="share-match-teams">${m.teams}</span>
          <span class="share-match-cat">${EMOJI[cat] || ''}</span>
        </label>`;
      });
      html += `</div>`;
    }
    html += `</div>`;
    return html;
  }

  function render() {
    const root = document.getElementById('share-root');
    if (!root) return;

    const allMatches: Match[] = JSON.parse(root.dataset.matches || '[]');

    // Filter to today only, then split by server
    const todayMatches = allMatches.filter(m => isToday(m.startTime));
    const byServer: Record<number, Match[]> = { 1: [], 2: [], 3: [] };
    todayMatches.forEach(m => { if (byServer[m.server]) byServer[m.server].push(m); });

    // Sort each server's matches by startTime
    [1, 2, 3].forEach(s => byServer[s].sort((a, b) => (a.startTime || 0) - (b.startTime || 0)));

    // Selection state: keyed as "id-server" to allow same match on multiple servers
    const selected = new Set<string>();
    todayMatches.forEach(m => selected.add(m.id + '-' + m.server));

    function getServerMatches(serverNum: number) {
      return byServer[serverNum].filter(m => selected.has(m.id + '-' + serverNum));
    }

    function updatePreview(serverNum: number) {
      const pre = document.getElementById(`preview-${serverNum}`);
      if (pre) pre.textContent = buildServerText(getServerMatches(serverNum), serverNum);
      const countEl = document.querySelector<HTMLElement>(`.share-count[data-server="${serverNum}"]`);
      if (countEl) countEl.textContent = `${getServerMatches(serverNum).length} / ${byServer[serverNum].length} partidos`;
    }

    // --- Render tabs + panels ---
    const totalToday = todayMatches.length;
    let html = `<p class="share-today-count">📅 ${totalToday} partidos hoy · Selecciona y copia</p>`;

    // Tabs
    html += `<div class="server-tabs share-server-tabs" role="tablist">`;
    [1, 2, 3].forEach(s => {
      const count = byServer[s].length;
      html += `<button class="server-tab${s === 1 ? ' active' : ''}" role="tab" data-tab="${s}">
        <span class="tab-dot"></span> Servidor ${s} <span class="tab-badge">${count}</span>
      </button>`;
    });
    html += `</div>`;

    // Server panels (left: list, right: preview)
    [1, 2, 3].forEach(s => {
      html += `<div class="share-tab-panel${s === 1 ? '' : ' hidden'}" data-panel="${s}">
        <div class="share-layout">
          <div class="share-left">
            <h2 class="share-section-title">Servidor ${s} — Partidos de hoy</h2>
            ${renderServer(byServer[s], s, selected)}
          </div>
          <div class="share-right">
            <h2 class="share-section-title">Vista previa · Servidor ${s}</h2>
            <pre id="preview-${s}" class="share-preview">${buildServerText(byServer[s], s)}</pre>
          </div>
        </div>
      </div>`;
    });

    root.innerHTML = html;

    // Wire tab switching
    root.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach(tab => {
      tab.addEventListener('click', () => {
        root.querySelectorAll('[data-tab]').forEach(t => t.classList.remove('active'));
        root.querySelectorAll<HTMLElement>('[data-panel]').forEach(p => p.classList.add('hidden'));
        tab.classList.add('active');
        root.querySelector<HTMLElement>(`[data-panel="${tab.dataset.tab}"]`)?.classList.remove('hidden');
      });
    });

    // Wire checkboxes
    root.querySelectorAll<HTMLInputElement>('input[type=checkbox][data-id]').forEach(chk => {
      chk.addEventListener('change', () => {
        const key = chk.dataset.id + '-' + chk.dataset.server;
        if (chk.checked) selected.add(key); else selected.delete(key);
        updatePreview(Number(chk.dataset.server));
      });
    });

    // Copy server
    root.querySelectorAll<HTMLButtonElement>('.share-copy-server').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        copyText(buildServerText(getServerMatches(s), s), btn);
      });
    });

    // Select/deselect all for server
    root.querySelectorAll<HTMLButtonElement>('.share-select-all').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        byServer[s].forEach(m => selected.add(m.id + '-' + s));
        root.querySelectorAll<HTMLInputElement>(`input[data-server="${s}"]`).forEach(c => c.checked = true);
        updatePreview(s);
      });
    });
    root.querySelectorAll<HTMLButtonElement>('.share-deselect-all').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        byServer[s].forEach(m => selected.delete(m.id + '-' + s));
        root.querySelectorAll<HTMLInputElement>(`input[data-server="${s}"]`).forEach(c => c.checked = false);
        updatePreview(s);
      });
    });

    // Copy by category
    root.querySelectorAll<HTMLButtonElement>('.share-cat-copy').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        const cat = btn.dataset.cat!;
        const catMatches = byServer[s].filter(m => m.category === cat && selected.has(m.id + '-' + s));
        if (!catMatches.length) return;
        let text = `🔴 DEPORTES EN VIVO - ${formatDate()}\n${SERVER_LABEL[s]} · https://${SITE}\n\n`;
        text += `${EMOJI[cat] || '🏆'} ${CAT_LABEL[cat] || cat.toUpperCase()}\n\n`;
        catMatches.forEach(m => {
          const live = isLive(m) ? ' 🔴 EN VIVO' : '';
          text += `• ${formatTime(m.startTime)}${live} ${m.teams}\n  https://${SITE}/match/${m.id}\n\n`;
        });
        text += `📺 Ver todos → https://${SITE}`;
        copyText(text, btn);
      });
    });

    // Init previews
    [1, 2, 3].forEach(s => updatePreview(s));
  }

  document.addEventListener('DOMContentLoaded', render);
</script>

<style>
  .share-today-count {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 1rem 0 1.25rem;
    font-weight: 600;
  }
  .share-server-tabs { margin-bottom: 0; }
  .tab-badge {
    display: inline-block;
    background: var(--surface-hover);
    border-radius: 999px;
    font-size: 0.68rem;
    padding: 1px 6px;
    font-weight: 700;
    margin-left: 4px;
    vertical-align: middle;
  }
  .server-tab.active .tab-badge { background: rgba(255,255,255,0.2); }

  .share-tab-panel { margin-top: 1.25rem; }
  .share-tab-panel.hidden { display: none; }

  .share-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 900px) { .share-layout { grid-template-columns: 1fr; } }

  .share-section-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .share-server-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .share-count {
    margin-left: auto;
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 600;
  }
  .share-category { margin-bottom: 1.25rem; }
  .share-cat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
    padding: 0.3rem 0.5rem;
    background: var(--surface);
    border-radius: 6px;
  }
  .share-cat-copy { font-size: 0.7rem; padding: 0.15rem 0.5rem; }

  .share-match-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.12s;
  }
  .share-match-row:hover { background: var(--surface-hover); }
  .share-match-row.is-live { border-left: 2px solid var(--primary); padding-left: 0.4rem; }
  .share-match-row input[type=checkbox] { accent-color: var(--primary); flex-shrink: 0; }
  .share-match-time {
    font-size: 0.78rem;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    min-width: 2.2rem;
    font-weight: 600;
  }
  .share-match-teams {
    font-size: 0.85rem;
    color: var(--text);
    font-weight: 600;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .share-match-cat { font-size: 0.85rem; flex-shrink: 0; }

  .share-right { position: sticky; top: 80px; align-self: start; }
  .share-preview {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.875rem;
    font-size: 0.76rem;
    line-height: 1.65;
    color: var(--text);
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 55vh;
    overflow-y: auto;
    font-family: 'Courier New', monospace;
  }

  .share-empty {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    border: 1px dashed var(--border);
    border-radius: 8px;
  }

  /* copy button is below the preview */
  .share-right .share-section-title + .share-preview { margin-bottom: 0.75rem; }
</style>
