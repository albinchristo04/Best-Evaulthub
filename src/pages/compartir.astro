---
import BaseLayout from '../layouts/BaseLayout.astro';
import allMatches from '../data/all-matches.json';
---

<BaseLayout
  title="Compartir Partidos de Hoy"
  description="Comparte los partidos de hoy por Telegram o WhatsApp. Organizados por servidor."
  canonicalUrl="https://deportesenvivo.live/compartir"
  pageType="share"
>
  <div class="container">

    <!-- Header -->
    <div class="share-header">
      <div class="share-header-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
      </div>
      <div>
        <h1 class="share-title">Compartir Partidos de Hoy</h1>
        <p class="share-subtitle">Selecciona partidos y copia en formato Telegram o WhatsApp</p>
      </div>
    </div>

    <!-- Stats bar -->
    <div id="share-stats" class="share-stats" aria-live="polite"></div>

    <!-- Timezone picker (rendered by JS) -->
    <div id="tz-picker"></div>

    <!-- Main content injected by JS -->
    <div id="share-root" data-matches={JSON.stringify(allMatches)}></div>

  </div>
</BaseLayout>

<script>
  const SITE = 'deportesenvivo.live';

  const TIMEZONES: { label: string; flag: string; tz: string | null }[] = [
    { label: 'Local',      flag: '🌐', tz: null },
    { label: 'España',     flag: '🇪🇸', tz: 'Europe/Madrid' },
    { label: 'México',     flag: '🇲🇽', tz: 'America/Mexico_City' },
    { label: 'Argentina',  flag: '🇦🇷', tz: 'America/Argentina/Buenos_Aires' },
    { label: 'Colombia',   flag: '🇨🇴', tz: 'America/Bogota' },
    { label: 'Perú',       flag: '🇵🇪', tz: 'America/Lima' },
    { label: 'Chile',      flag: '🇨🇱', tz: 'America/Santiago' },
    { label: 'Venezuela',  flag: '🇻🇪', tz: 'America/Caracas' },
    { label: 'India',      flag: '🇮🇳', tz: 'Asia/Kolkata' },
    { label: 'Brasil',     flag: '🇧🇷', tz: 'America/Sao_Paulo' },
    { label: 'USA (ET)',   flag: '🇺🇸', tz: 'America/New_York' },
    { label: 'USA (PT)',   flag: '🇺🇸', tz: 'America/Los_Angeles' },
    { label: 'UK',         flag: '🇬🇧', tz: 'Europe/London' },
    { label: 'Alemania',   flag: '🇩🇪', tz: 'Europe/Berlin' },
    { label: 'Arabia',     flag: '🇸🇦', tz: 'Asia/Riyadh' },
    { label: 'Japón',      flag: '🇯🇵', tz: 'Asia/Tokyo' },
    { label: 'Australia',  flag: '🇦🇺', tz: 'Australia/Sydney' },
  ];

  // Module-level timezone state — survives tab switches and checkbox changes
  let currentTz: string | null = null;

  const EMOJI: Record<string, string> = {
    football: '⚽', basketball: '🏀', baseball: '⚾', tennis: '🎾',
    cricket: '🏏', hockey: '🏒', boxing: '🥊', mma: '🥊', darts: '🎯', other: '🏆'
  };
  const CAT_LABEL: Record<string, string> = {
    football: 'Fútbol', basketball: 'NBA / Baloncesto', baseball: 'MLB / Béisbol',
    tennis: 'Tenis', cricket: 'Cricket', hockey: 'Hockey', boxing: 'Boxeo',
    mma: 'MMA / UFC', darts: 'Dardos', other: 'Otros Deportes'
  };
  const SERVER_LABEL: Record<number, string> = { 1: 'Servidor 1', 2: 'Servidor 2', 3: 'Servidor 3' };

  interface Match {
    id: string; teams: string; category: string;
    startTime: number; endTime: number; server: number;
  }

  function isToday(ts: number): boolean {
    if (!ts) return true;
    const d = new Date(ts * 1000), now = new Date();
    return d.getFullYear() === now.getFullYear() && d.getMonth() === now.getMonth() && d.getDate() === now.getDate();
  }

  function formatTime(ts: number, tz?: string | null): string {
    if (!ts) return 'EN VIVO';
    const resolvedTz = tz !== undefined ? tz : currentTz;
    const opts: Intl.DateTimeFormatOptions = { hour: '2-digit', minute: '2-digit' };
    if (resolvedTz) opts.timeZone = resolvedTz;
    return new Intl.DateTimeFormat(navigator.language || 'es', opts).format(new Date(ts * 1000));
  }

  function tzLabel(): string {
    if (!currentTz) return '';
    const entry = TIMEZONES.find(t => t.tz === currentTz);
    return entry ? ` (${entry.flag} ${entry.label})` : '';
  }

  function formatDateLong(): string {
    return new Intl.DateTimeFormat('es-ES', { weekday: 'long', day: '2-digit', month: 'long' }).format(new Date());
  }

  function formatDateShort(): string {
    return new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' }).format(new Date());
  }

  function isLive(m: Match): boolean {
    const now = Math.floor(Date.now() / 1000);
    return m.startTime > 0 && now >= m.startTime && (m.endTime === 0 || now <= m.endTime);
  }

  function buildText(matches: Match[], serverNum: number): string {
    const byCategory: Record<string, Match[]> = {};
    matches.forEach(m => { if (!byCategory[m.category]) byCategory[m.category] = []; byCategory[m.category].push(m); });
    const tzSuffix = tzLabel();
    let text = `🔴 DEPORTES EN VIVO — ${formatDateShort()}${tzSuffix}\n${SERVER_LABEL[serverNum]} · https://${SITE}\n`;
    for (const [cat, evts] of Object.entries(byCategory)) {
      text += `\n${EMOJI[cat] || '🏆'} ${CAT_LABEL[cat]?.toUpperCase() || cat.toUpperCase()}\n\n`;
      evts.forEach(m => {
        const live = isLive(m) ? ' 🔴 EN VIVO' : '';
        text += `• ${formatTime(m.startTime)}${live} ${m.teams}\n  https://${SITE}/match/${m.id}\n\n`;
      });
    }
    text += `📺 Ver todos → https://${SITE}`;
    return text;
  }

  function copyText(text: string, btn: HTMLButtonElement) {
    const orig = btn.innerHTML;
    const done = () => {
      btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> ¡Copiado!`;
      btn.classList.add('copied');
      btn.disabled = true;
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); btn.disabled = false; }, 2200);
    };
    navigator.clipboard.writeText(text).then(done).catch(() => {
      const ta = Object.assign(document.createElement('textarea'), { value: text, style: 'position:fixed;opacity:0' });
      document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
      done();
    });
  }

  function renderMatchList(matches: Match[], serverNum: number, selected: Set<string>): string {
    if (!matches.length) return `<div class="share-empty"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p>Sin partidos hoy en ${SERVER_LABEL[serverNum]}</p></div>`;

    const byCategory: Record<string, Match[]> = {};
    matches.forEach(m => { if (!byCategory[m.category]) byCategory[m.category] = []; byCategory[m.category].push(m); });

    let html = '';
    for (const [cat, evts] of Object.entries(byCategory)) {
      html += `<div class="share-category">
        <div class="share-cat-header">
          <span class="share-cat-label">${EMOJI[cat] || '🏆'} ${CAT_LABEL[cat] || cat}</span>
          <button class="share-cat-copy btn-ghost-sm" data-server="${serverNum}" data-cat="${cat}" aria-label="Copiar ${CAT_LABEL[cat] || cat}">Copiar</button>
        </div>`;
      evts.forEach(m => {
        const live = isLive(m);
        const chkId = `chk-s${serverNum}-${m.id}`;
        const isChecked = selected.has(m.id + '-' + serverNum);
        html += `<label class="share-match-row${live ? ' is-live' : ''}" for="${chkId}">
          <input type="checkbox" id="${chkId}" data-id="${m.id}" data-server="${serverNum}" ${isChecked ? 'checked' : ''}/>
          <span class="share-match-time${live ? ' live-text' : ''}" data-ts="${m.startTime}">${live ? '🔴' : formatTime(m.startTime)}</span>
          <span class="share-match-teams">${m.teams}</span>
          ${live ? '<span class="live-pill">EN VIVO</span>' : ''}
        </label>`;
      });
      html += `</div>`;
    }
    return html;
  }

  function renderTzPicker() {
    const el = document.getElementById('tz-picker');
    if (!el) return;
    el.innerHTML = `
      <div class="tz-bar">
        <div class="tz-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Horario:
        </div>
        <div class="tz-pills" role="group" aria-label="Seleccionar zona horaria">
          ${TIMEZONES.map(t => `
            <button
              class="tz-pill${t.tz === currentTz ? ' active' : ''}"
              data-tz="${t.tz ?? ''}"
              aria-pressed="${t.tz === currentTz}"
            >${t.flag} ${t.label}</button>
          `).join('')}
        </div>
      </div>`;
  }

  function render() {
    const root = document.getElementById('share-root');
    const statsEl = document.getElementById('share-stats');
    if (!root) return;

    const allMatches: Match[] = JSON.parse(root.dataset.matches || '[]');
    const todayMatches = allMatches.filter(m => isToday(m.startTime));
    const byServer: Record<number, Match[]> = { 1: [], 2: [], 3: [] };
    todayMatches.forEach(m => { if (byServer[m.server]) byServer[m.server].push(m); });
    [1, 2, 3].forEach(s => byServer[s].sort((a, b) => (a.startTime || 0) - (b.startTime || 0)));

    const liveCount = todayMatches.filter(m => isLive(m)).length;
    const selected = new Set<string>();
    todayMatches.forEach(m => selected.add(m.id + '-' + m.server));

    // Stats bar
    if (statsEl) {
      statsEl.innerHTML = `
        <div class="stat-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>${formatDateLong()}</span>
        </div>
        <div class="stat-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>${todayMatches.length} partidos</span>
        </div>
        ${liveCount > 0 ? `<div class="stat-item stat-live"><span class="live-dot"></span><span>${liveCount} en vivo</span></div>` : ''}
      `;
    }

    function getSelected(serverNum: number) {
      return byServer[serverNum].filter(m => selected.has(m.id + '-' + serverNum));
    }

    function updatePreview(serverNum: number) {
      const pre = document.getElementById(`preview-${serverNum}`);
      const countEl = document.querySelector<HTMLElement>(`.share-count[data-server="${serverNum}"]`);
      const sel = getSelected(serverNum);
      if (pre) pre.textContent = buildText(sel, serverNum);
      if (countEl) countEl.textContent = `${sel.length} / ${byServer[serverNum].length}`;
    }

    // Update all visible time spans + all previews (called on tz change)
    function applyTimezone() {
      document.querySelectorAll<HTMLElement>('.share-match-time[data-ts]').forEach(el => {
        const ts = Number(el.dataset.ts);
        if (!ts) return;
        el.textContent = formatTime(ts);
      });
      [1, 2, 3].forEach(s => updatePreview(s));
    }

    // Build HTML — server tabs
    let html = `<div class="server-tabs share-server-tabs" role="tablist">`;
    [1, 2, 3].forEach(s => {
      const count = byServer[s].length;
      html += `<button class="server-tab${s === 1 ? ' active' : ''}" role="tab" aria-selected="${s === 1}" data-tab="${s}">
        Servidor ${s}
        <span class="tab-badge">${count}</span>
      </button>`;
    });
    html += `</div>`;

    [1, 2, 3].forEach(s => {
      html += `<div class="share-tab-panel${s === 1 ? '' : ' hidden'}" data-panel="${s}">
        <div class="share-layout">
          <div class="share-left">
            <div class="share-toolbar">
              <div class="share-toolbar-left">
                <span class="share-count-badge" data-server="${s}">
                  <span class="share-count" data-server="${s}">${byServer[s].length} / ${byServer[s].length}</span> seleccionados
                </span>
              </div>
              <div class="share-toolbar-right">
                <button class="btn-ghost-sm share-select-all" data-server="${s}">Todos</button>
                <button class="btn-ghost-sm share-deselect-all" data-server="${s}">Ninguno</button>
              </div>
            </div>
            <div class="share-match-list">
              ${renderMatchList(byServer[s], s, selected)}
            </div>
          </div>
          <div class="share-right">
            <div class="share-preview-card">
              <div class="share-preview-header">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Vista previa · Servidor ${s}
              </div>
              <pre id="preview-${s}" class="share-preview">${buildText(byServer[s], s)}</pre>
              <div class="share-copy-actions">
                <button class="share-copy-btn share-copy-server" data-server="${s}" aria-label="Copiar texto Servidor ${s}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  Copiar texto
                </button>
                <button class="share-whatsapp-btn" data-server="${s}" aria-label="Compartir por WhatsApp">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                  WhatsApp
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>`;
    });

    root.innerHTML = html;

    // ── Wire events ──────────────────────────────────────────

    // Tab switching
    root.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach(tab => {
      tab.addEventListener('click', () => {
        root.querySelectorAll('[data-tab]').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        root.querySelectorAll<HTMLElement>('[data-panel]').forEach(p => p.classList.add('hidden'));
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        root.querySelector<HTMLElement>(`[data-panel="${tab.dataset.tab}"]`)?.classList.remove('hidden');
      });
    });

    // Checkboxes
    root.querySelectorAll<HTMLInputElement>('input[type=checkbox][data-id]').forEach(chk => {
      chk.addEventListener('change', () => {
        const key = chk.dataset.id + '-' + chk.dataset.server;
        if (chk.checked) selected.add(key); else selected.delete(key);
        updatePreview(Number(chk.dataset.server));
      });
    });

    // Copy server button
    root.querySelectorAll<HTMLButtonElement>('.share-copy-btn.share-copy-server').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        copyText(buildText(getSelected(s), s), btn);
      });
    });

    // WhatsApp share
    root.querySelectorAll<HTMLButtonElement>('.share-whatsapp-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        const text = buildText(getSelected(s), s);
        window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank', 'noopener');
      });
    });

    // Select/deselect all
    root.querySelectorAll<HTMLButtonElement>('.share-select-all').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        byServer[s].forEach(m => selected.add(m.id + '-' + s));
        root.querySelectorAll<HTMLInputElement>(`input[data-server="${s}"]`).forEach(c => c.checked = true);
        updatePreview(s);
      });
    });
    root.querySelectorAll<HTMLButtonElement>('.share-deselect-all').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = Number(btn.dataset.server);
        byServer[s].forEach(m => selected.delete(m.id + '-' + s));
        root.querySelectorAll<HTMLInputElement>(`input[data-server="${s}"]`).forEach(c => c.checked = false);
        updatePreview(s);
      });
    });

    // Copy by category
    root.querySelectorAll<HTMLButtonElement>('.share-cat-copy').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        const s = Number(btn.dataset.server);
        const cat = btn.dataset.cat!;
        const catMatches = byServer[s].filter(m => m.category === cat && selected.has(m.id + '-' + s));
        if (!catMatches.length) return;
        let text = `🔴 DEPORTES EN VIVO — ${formatDateShort()}${tzLabel()}\n${SERVER_LABEL[s]} · https://${SITE}\n\n`;
        text += `${EMOJI[cat] || '🏆'} ${CAT_LABEL[cat]?.toUpperCase() || cat.toUpperCase()}\n\n`;
        catMatches.forEach(m => {
          const live = isLive(m) ? ' 🔴 EN VIVO' : '';
          text += `• ${formatTime(m.startTime)}${live} ${m.teams}\n  https://${SITE}/match/${m.id}\n\n`;
        });
        text += `📺 Ver todos → https://${SITE}`;
        copyText(text, btn);
      });
    });

    // Timezone pill clicks
    document.querySelectorAll<HTMLButtonElement>('.tz-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        currentTz = pill.dataset.tz || null;
        // Update active state
        document.querySelectorAll('.tz-pill').forEach(p => {
          const active = (p as HTMLButtonElement).dataset.tz === (currentTz ?? '');
          p.classList.toggle('active', active);
          p.setAttribute('aria-pressed', String(active));
        });
        // Update times in DOM + previews (no full re-render → preserves checkboxes)
        applyTimezone();
      });
    });

    [1, 2, 3].forEach(s => updatePreview(s));
  }

  document.addEventListener('DOMContentLoaded', () => {
    renderTzPicker();
    render();
  });
</script>

<style>
  /* ── Page header ──────────────────────────────────────── */
  .share-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 2rem 0 0;
  }

  .share-header-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, var(--primary) 0%, #c53030 100%);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(229, 62, 62, 0.35);
  }

  .share-title {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }

  .share-subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  /* ── Stats bar ────────────────────────────────────────── */
  .share-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin: 1.25rem 0 0;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px 10px 0 0;
    border-bottom: none;
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 600;
    min-height: 44px;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .stat-live { color: var(--primary); }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--primary);
    animation: pulse 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* ── Timezone picker ──────────────────────────────────── */
  .tz-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0 0 10px 10px;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .tz-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tz-pills {
    display: flex;
    gap: 0.375rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2px;
    flex: 1;
  }

  .tz-pills::-webkit-scrollbar { display: none; }

  .tz-pill {
