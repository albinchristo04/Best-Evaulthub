---
import BaseLayout from '../layouts/BaseLayout.astro';
import MatchGrid from '../components/MatchGrid.astro';
import ServerTabs from '../components/ServerTabs.astro';
import FAQ from '../components/FAQ.astro';
import s1Matches from '../data/s1-matches.json';
import s2Matches from '../data/s2-matches.json';
import s3Matches from '../data/s3-matches.json';

const title = "LaLiga en Vivo - Ver Fútbol Español Gratis Hoy";
const description = "Ver LaLiga en vivo gratis hoy. Partidos de LaLiga española en directo sin registro. Liga española online gratis.";
const keywords = "laliga en vivo, ver laliga gratis, laliga hoy, liga española en vivo, laliga online, ver laliga en directo, laliga partidos hoy, liga española gratis, laliga ea sports";

const filterCategory = "football";
const filteredS1 = s1Matches.filter((m: any) => m.category === filterCategory);
const filteredS2 = s2Matches.filter((m: any) => m.category === filterCategory);
const filteredS3 = s3Matches.filter((m: any) => m.category === filterCategory);

const faqItems = [
  {
    question: "¿Dónde ver LaLiga en vivo gratis?",
    answer: "En deportesenvivo.live puedes ver LaLiga en vivo gratis sin suscripción. Entra al sitio, selecciona el partido de LaLiga española que quieres ver y haz clic en 'Ver en vivo'. Disponible con tres servidores para máxima disponibilidad.",
  },
  {
    question: "¿A qué hora son los partidos de LaLiga hoy?",
    answer: "Los partidos de LaLiga se juegan normalmente los viernes, sábados y domingos. Los horarios varían: hay partidos a las 14:00, 16:15, 18:30 y 21:00 hora española. En deportesenvivo.live los horarios se muestran en tu zona horaria local automáticamente.",
  },
  {
    question: "¿Qué canal transmite LaLiga?",
    answer: "En España, LaLiga se emite principalmente en Movistar+ y DAZN. En Latinoamérica en ESPN y Star+. En deportesenvivo.live ofrecemos una alternativa gratuita para ver los partidos de la liga española sin necesidad de suscripción.",
  },
  {
    question: "¿Puedo ver el clásico Real Madrid vs Barcelona gratis?",
    answer: "Sí. En deportesenvivo.live encontrarás streaming gratuito del clásico Real Madrid vs Barcelona y de todos los grandes partidos de LaLiga, incluyendo los derbis locales y los encuentros de los equipos punteros de la clasificación.",
  },
  {
    question: "¿Cuántos equipos hay en LaLiga EA Sports?",
    answer: "LaLiga EA Sports (antes Primera División) cuenta con 20 equipos que se enfrentan en formato liga durante la temporada. Al final, los tres últimos clasificados descienden a la Segunda División y son reemplazados por los tres primeros de la categoría inferior.",
  },
  {
    question: "¿Cuándo empieza la temporada de LaLiga?",
    answer: "La temporada de LaLiga comienza en agosto y finaliza en mayo. En deportesenvivo.live puedes seguir todos los partidos de LaLiga a lo largo de toda la temporada, incluyendo las últimas jornadas de la liga que suelen ser las más emocionantes.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalUrl="https://deportesenvivo.live/laliga"
  pageType="hub"
  jsonLd={faqJsonLd}
>
  <div class="container">
    <div class="page-header">
      <h1>LaLiga en Vivo</h1>
      <p class="subtitle">Ver Liga española gratis online — partidos de LaLiga en directo sin registro</p>
    </div>

    <ServerTabs activeServer={1} />

    <div id="server-content-1">
      <MatchGrid matches={filteredS1} serverNum={1} />
    </div>
    <div id="server-content-2" hidden>
      <MatchGrid matches={filteredS2} serverNum={2} />
    </div>
    <div id="server-content-3" hidden>
      <MatchGrid matches={filteredS3} serverNum={3} />
    </div>

    <div class="seo-content">
      <h2>Ver LaLiga en Vivo Online — Liga Española Gratis</h2>
      <p>
        <strong>LaLiga en vivo</strong> es la competición de fútbol más seguida en el mundo hispanohablante. En deportesenvivo.live ofrecemos streaming gratuito de todos los partidos de la <strong>liga española</strong>, incluyendo el clásico Real Madrid vs Barcelona, los derbis locales y las jornadas decisivas de la clasificación. Tres servidores disponibles para que siempre encuentres una transmisión funcionando.
      </p>
      <p>
        Para <strong>ver LaLiga hoy</strong>, consulta la cartelera de partidos disponible arriba. Todos los encuentros de <strong>LaLiga EA Sports</strong> aparecen con su horario en tu zona horaria local. Cuando el partido está en curso verás el indicador EN VIVO en rojo. También puedes explorar <a href="/champions-league">Champions League</a>, <a href="/futbol-libre">Fútbol Libre</a> o <a href="/tarjeta-roja">Tarjeta Roja</a> para más opciones de fútbol en vivo.
      </p>
      <p>
        ¿Quieres <strong>ver la liga española gratis</strong> sin pagar suscripciones a Movistar+ o DAZN? deportesenvivo.live es la alternativa perfecta: acceso gratuito desde cualquier dispositivo, sin registro y con múltiples servidores para garantizar la mejor disponibilidad en cada partido.
      </p>
      <h3>LaLiga partidos hoy — Todos los equipos en directo</h3>
      <p>
        Los equipos de <strong>LaLiga</strong> que más búsquedas generan son Real Madrid, FC Barcelona, Atlético de Madrid, Sevilla, Real Sociedad y Athletic Club. En deportesenvivo.live encontrarás los partidos de todos ellos cuando se transmitan. Sigue también la <a href="/copa-libertadores">Copa Libertadores</a> y la <a href="/liga-mx">Liga MX</a> para más fútbol internacional.
      </p>
    </div>

    <FAQ items={faqItems} />

    <div class="alternatives-box">
      <h3>Otras competiciones populares</h3>
      <div class="alt-links">
        <a href="/champions-league">Champions League</a>
        <a href="/liga-mx">Liga MX</a>
        <a href="/copa-libertadores">Copa Libertadores</a>
        <a href="/futbol-en-vivo">Fútbol en Vivo</a>
        <a href="/futbol-libre">Fútbol Libre</a>
        <a href="/pirlo-tv">Pirlo TV</a>
        <a href="/roja-directa">Roja Directa</a>
        <a href="/partidos-de-hoy">Partidos de Hoy</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .alternatives-box {
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .alternatives-box h3 {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .alt-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .alt-links a {
    padding: 0.3rem 0.85rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.85rem;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .alt-links a:hover { border-color: var(--primary); color: var(--primary); }
</style>
