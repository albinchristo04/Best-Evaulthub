---
import BaseLayout from '../layouts/BaseLayout.astro';
import MatchGrid from '../components/MatchGrid.astro';
import ServerTabs from '../components/ServerTabs.astro';
import FAQ from '../components/FAQ.astro';
import s1Matches from '../data/s1-matches.json';
import s2Matches from '../data/s2-matches.json';
import s3Matches from '../data/s3-matches.json';

const title = "Tarjeta Roja TV en Vivo - Ver Fútbol Hoy Gratis";
const description = "Tarjeta Roja TV en vivo hoy. Ver fútbol gratis sin registro.";
const keywords = "tarjeta roja tv, tarjeta roja tv en vivo, tarjeta roja tv hoy, tarjeta roja tv online";

const filterCategory = "football";
const filteredS1 = s1Matches.filter((m: any) => m.category === filterCategory);
const filteredS2 = s2Matches.filter((m: any) => m.category === filterCategory);
const filteredS3 = s3Matches.filter((m: any) => m.category === filterCategory);

const faqItems = [
  {
    question: "¿Qué diferencia hay entre Tarjeta Roja y Tarjeta Roja TV?",
    answer: "Tarjeta Roja TV es la versión televisiva o de canales de la plataforma Tarjeta Roja. Mientras que Tarjeta Roja ofrece links a eventos, Tarjeta Roja TV se enfoca en retransmitir canales deportivos completos. En deportesenvivo.live encontrarás ambos tipos de contenido.",
  },
  {
    question: "¿Tarjeta Roja TV funciona en Smart TV?",
    answer: "deportesenvivo.live está diseñado principalmente para navegadores web en PC, móvil y tablet. Para verlo en Smart TV, puedes usar la función de espejo de pantalla o Chromecast desde tu teléfono, o abrir el navegador web de tu Smart TV.",
  },
  {
    question: "¿Puedo ver el fútbol de hoy en Tarjeta Roja TV en vivo?",
    answer: "Sí. En deportesenvivo.live encontrarás todos los partidos de hoy listados con su hora local. Los eventos en curso muestran el badge EN VIVO en rojo. Simplemente haz clic en el partido que quieres ver y elige un servidor.",
  },
  {
    question: "¿Tarjeta Roja TV tiene publicidad excesiva?",
    answer: "deportesenvivo.live tiene una publicidad mínima y los streams de terceros están en un iframe aislado (sandbox) que bloquea los popups agresivos del reproductor. Solo verás la publicidad razonable de nuestra plataforma.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalUrl="https://deportesenvivo.live/tarjeta-roja-tv"
  pageType="hub"
  jsonLd={faqJsonLd}
>
  <div class="container">
    <div class="page-header">
      <h1>Tarjeta Roja TV</h1>
      <p class="subtitle">Ver fútbol hoy gratis sin registro — Tarjeta Roja TV en vivo</p>
    </div>

    <ServerTabs activeServer={1} />

    <div id="server-content-1">
      <MatchGrid matches={filteredS1} serverNum={1} />
    </div>
    <div id="server-content-2" hidden>
      <MatchGrid matches={filteredS2} serverNum={2} />
    </div>
    <div id="server-content-3" hidden>
      <MatchGrid matches={filteredS3} serverNum={3} />
    </div>

    <div class="seo-content">
      <h2>Tarjeta Roja TV — Ver Fútbol en Vivo Sin Registro</h2>
      <p>
        <strong>Tarjeta Roja TV</strong> es uno de los nombres más reconocidos en el mundo del streaming deportivo gratuito. En deportesenvivo.live ofrecemos todo lo que buscas en <strong>Tarjeta Roja TV en vivo</strong>: transmisiones de fútbol en directo, con múltiples servidores y calidad de imagen optimizada. Ver fútbol gratis hoy es tan sencillo como abrir el sitio, elegir el partido y pulsar reproducir.
      </p>
      <p>
        <strong>Tarjeta Roja TV hoy</strong> en deportesenvivo.live te ofrece la programación completa de los partidos de fútbol disponibles en este momento. Cubrimos LaLiga, Premier League, Serie A, Bundesliga, Champions League, Europa League, Copa del Rey, Copas nacionales y partidos internacionales. Los horarios se ajustan automáticamente a tu zona horaria.
      </p>
      <p>
        Si buscas más opciones de streaming gratuito, visita también <a href="/tarjeta-roja">Tarjeta Roja</a>, <a href="/futbol-libre-tv">Fútbol Libre TV</a>, <a href="/rojadirecta-tv">Rojadirecta TV</a> o <a href="/partidos-de-hoy">Partidos de Hoy</a>. Y no olvides compartir los partidos del día con tus amigos usando nuestra <a href="/compartir">herramienta de compartir</a>.
      </p>
    </div>

    <FAQ items={faqItems} />
  </div>
</BaseLayout>
