---
/**
 * ServerTabs.astro
 * Renders server selection tabs and handles client-side show/hide of
 * .server-content-{n} divs.
 *
 * Props:
 *   activeServer  — which tab is active by default (1 | 2 | 3)
 *   showServers   — which server tabs to render (default [1,2,3])
 */

export interface Props {
  activeServer?: 1 | 2 | 3;
  showServers?: (1 | 2 | 3)[];
}

const { activeServer = 1, showServers = [1, 2, 3] } = Astro.props;

const labels: Record<number, string> = {
  1: 'Servidor 1',
  2: 'Servidor 2',
  3: 'Servidor 3',
};
---

<div class="server-tabs" role="tablist" aria-label="Seleccionar servidor">
  {showServers.map((n) => (
    <button
      class={`server-tab${n === activeServer ? ' active' : ''}`}
      role="tab"
      aria-selected={n === activeServer ? 'true' : 'false'}
      aria-controls={`server-content-${n}`}
      data-server={n}
      id={`server-tab-${n}`}
    >
      <span class="tab-dot" aria-hidden="true"></span>
      {labels[n]}
    </button>
  ))}
</div>

<style>
  .tab-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.6;
  }

  .server-tab.active .tab-dot {
    opacity: 1;
    background: #fff;
  }
</style>

<script>
  (function initServerTabs() {
    // Match panels by EITHER id="server-content-N" OR class containing "server-content-N"
    function getPanels(): NodeListOf<HTMLElement> {
      return document.querySelectorAll<HTMLElement>(
        '[id^="server-content-"], [class*="server-content-"]'
      );
    }

    function getPanelNum(el: HTMLElement): string | null {
      const fromId = el.id.match(/server-content-(\d)/);
      if (fromId) return fromId[1];
      const fromClass = el.className.match(/server-content-(\d)/);
      return fromClass ? fromClass[1] : null;
    }

    const tabBars = document.querySelectorAll<HTMLElement>('.server-tabs');

    tabBars.forEach((bar) => {
      const tabs = bar.querySelectorAll<HTMLButtonElement>('[data-server]');
      const activeTab = bar.querySelector<HTMLButtonElement>('.server-tab.active');
      const activeServer = activeTab?.dataset.server ?? '1';

      // Init: hide all panels except the active server
      getPanels().forEach((panel) => {
        const num = getPanelNum(panel);
        if (num) panel.hidden = num !== activeServer;
      });

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const server = tab.dataset.server!;

          tabs.forEach((t) => {
            t.classList.toggle('active', t === tab);
            t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
          });

          getPanels().forEach((panel) => {
            const num = getPanelNum(panel);
            if (num) panel.hidden = num !== server;
          });
        });
      });
    });
  })();
</script>
